  .habit-name { font-size: 14px; }
}

.completion-circle { position: absolute; top: 5px; right: 5px; width: 25px; height: 25px; background: rgb(76, 175, 80); border-radius: 50%; display: none; align-items: center; justify-content: center; color: white; font-size: 16px; font-weight: bold; box-shadow: rgba(0, 0, 0, 0.2) 0px 2px 5px; }

.habit-card.completed .completion-circle { display: flex; }

.missed-circle { position: absolute; top: 5px; right: 5px; width: 25px; height: 25px; background: rgb(244, 67, 54); border-radius: 50%; display: none; align-items: center; justify-content: center; color: white; font-size: 16px; font-weight: bold; box-shadow: rgba(0, 0, 0, 0.2) 0px 2px 5px; }

.habit-card.missed .missed-circle { display: flex; }
