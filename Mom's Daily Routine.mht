@charset "utf-8";

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { font-family: Arial, "Segoe UI", sans-serif; background: linear-gradient(135deg, rgb(255, 107, 157) 0%, rgb(255, 160, 122) 100%); min-height: 100vh; padding: 10px; display: flex; justify-content: center; align-items: center; }

.container { width: 100%; max-width: 500px; background: white; border-radius: 30px; padding: 20px; box-shadow: rgba(255, 107, 157, 0.3) 0px 10px 40px; }

.header { text-align: center; margin-bottom: 20px; }

.header h1 { color: rgb(255, 107, 157); font-size: 28px; margin-bottom: 5px; display: flex; align-items: center; justify-content: center; gap: 10px; }

.header .date { color: rgb(102, 102, 102); font-size: 16px; font-weight: bold; }

.today-label { background: rgb(255, 224, 236); color: rgb(255, 107, 157); padding: 8px 16px; border-radius: 20px; font-size: 14px; font-weight: bold; margin-top: 5px; display: inline-block; }

.habits-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-bottom: 30px; }

.habit-card { background: white; border: 3px solid rgb(224, 224, 224); border-radius: 20px; padding: 15px; cursor: pointer; transition: 0.3s; display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; overflow: hidden; }

.habit-card:active { transform: scale(0.95); }

.habit-card.completed { background: linear-gradient(135deg, rgb(76, 175, 80) 0%, rgb(102, 187, 106) 100%); border-color: rgb(46, 125, 50); box-shadow: rgba(76, 175, 80, 0.3) 0px 8px 20px; }

.habit-card.missed { background: linear-gradient(135deg, rgb(244, 67, 54) 0%, rgb(239, 83, 80) 100%); border-color: rgb(198, 40, 40); box-shadow: rgba(244, 67, 54, 0.3) 0px 8px 20px; }

.habit-icon { font-size: 50px; margin-bottom: 10px; filter: drop-shadow(rgba(0, 0, 0, 0.1) 0px 2px 4px); }

.habit-name { font-size: 16px; font-weight: bold; color: rgb(51, 51, 51); margin-bottom: 5px; }

.habit-card.completed .habit-name { color: white; }

.habit-card.missed .habit-name { color: white; }

.habit-status { font-size: 12px; opacity: 0.8; color: rgb(102, 102, 102); }

.habit-card.completed .habit-status, .habit-card.missed .habit-status { color: white; }

.stats-section { background: rgb(255, 249, 230); border-radius: 20px; padding: 15px; margin-bottom: 20px; border: 2px dashed rgb(255, 215, 0); }

.stats-title { color: rgb(255, 107, 157); font-weight: bold; margin-bottom: 10px; font-size: 16px; }

.history-container { display: none; margin-top: 10px; }

.history-container.show { display: block; }

.history-date { font-size: 12px; color: rgb(153, 153, 153); margin-top: 8px; font-weight: bold; }

.history-items { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; margin-top: 5px; max-width: 280px; }

.history-item { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: bold; }

.history-item.completed { background: rgb(76, 175, 80); color: white; }

.history-item.missed { background: rgb(244, 67, 54); color: white; }

.modal { display: none; position: fixed; top: 0px; left: 0px; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.6); z-index: 1000; justify-content: center; align-items: center; }

.modal.show { display: flex; }

.modal-content { background: white; border-radius: 30px; padding: 40px 30px; text-align: center; max-width: 350px; animation: 0.3s ease 0s 1 normal none running popIn; }

@keyframes popIn { 
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.modal-icon { font-size: 60px; margin-bottom: 15px; }

.modal-title { font-size: 24px; color: rgb(51, 51, 51); margin-bottom: 20px; font-weight: bold; }

.modal-question { font-size: 20px; color: rgb(255, 107, 157); margin-bottom: 30px; font-weight: bold; }

.button-group { display: flex; gap: 15px; justify-content: center; }

.btn { padding: 15px 35px; border: none; border-radius: 20px; font-size: 18px; font-weight: bold; cursor: pointer; transition: 0.3s; min-width: 100px; }

.btn-yes { background: linear-gradient(135deg, rgb(76, 175, 80) 0%, rgb(102, 187, 106) 100%); color: white; box-shadow: rgba(76, 175, 80, 0.3) 0px 5px 15px; }

.btn-yes:active { transform: scale(0.95); }

.btn-no { background: linear-gradient(135deg, rgb(244, 67, 54) 0%, rgb(239, 83, 80) 100%); color: white; box-shadow: rgba(244, 67, 54, 0.3) 0px 5px 15px; }

.btn-no:active { transform: scale(0.95); }

.tab-buttons { display: flex; gap: 10px; margin-bottom: 20px; }

.tab-btn { flex: 1 1 0%; padding: 12px; border: 2px solid rgb(221, 221, 221); background: white; border-radius: 15px; cursor: pointer; font-weight: bold; color: rgb(153, 153, 153); transition: 0.3s; }

.tab-btn.active { background: linear-gradient(135deg, rgb(255, 107, 157) 0%, rgb(255, 160, 122) 100%); color: white; border-color: rgb(255, 107, 157); }

.emoji-check { display: inline-block; margin-left: 5px; }

@media (max-width: 480px) {
